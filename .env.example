# Server
GAP_SERVER_ADDR=:8080
GAP_SERVER_ADMIN_KEY=change-me-admin-key

# Auth (Grok CLI auth.json)
GAP_AUTH_FILE=/config/auth.json
GAP_AUTH_UPSTREAM_BASE=https://api.x.ai/v1
GAP_AUTH_REFRESH_SKEW=5m
# GAP_AUTH_ISSUER=https://auth.x.ai
# GAP_AUTH_CLIENT_ID=

# Database (sqlite path or postgres DSN)
GAP_DB_DRIVER=sqlite
GAP_DB_DSN=/data/proxy.db
# GAP_DB_DRIVER=postgres
# GAP_DB_DSN=host=postgres user=proxy password=proxy dbname=proxy port=5432 sslmode=disable

# Rate limiting
GAP_RATE_LIMIT_RPS=10
GAP_RATE_LIMIT_BURST=20

# Logging
GAP_LOG_LEVEL=info
GAP_LOG_REDACT=true

# Metrics
GAP_METRICS_ENABLED=true
